# =====================================================================
# .gitignore — Predictive Maintenance (RUL) project
# =====================================================================

# ----- Internal tooling (Claude Code) --------------------------------
CLAUDE.md
.claude/

# ----- Data (large / licensed — document source in notebook) ---------
data/
!data/.gitkeep
!data/raw/.gitkeep

# ----- MLflow experiment tracking (large — regenerate by running notebook) --
mlruns/

# ----- Trained models (large binary artefacts — regenerate via notebook) --
models/
!models/.gitkeep
*.pkl
*.keras
*.h5
*.pt
*.pth

# ----- Credentials & secrets -----------------------------------------
.env
.env.*
.kaggle/
kaggle.json
*.token
secrets/

# ----- Python generated files ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# ----- Jupyter artefacts ---------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- Virtual environments ------------------------------------------
.venv/
venv/
env/
ENV/
.env/
.conda/

# ----- OS noise -------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- IDE & editor files --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# ----- Test / coverage artefacts -------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ----- Temporary & log files -----------------------------------------
*.log
*.tmp
*.temp
logs/
